# ForgePilot Agent - Production Baseline

FORGEPILOT_LOG_LEVEL=INFO
FORGEPILOT_EXPOSE_METRICS=true
FORGEPILOT_REQUEST_ID_HEADER=x-request-id

# Production CORS baseline: do not use wildcard.
FORGEPILOT_CORS_ORIGINS=https://console.example.com,https://ops.example.com
FORGEPILOT_CORS_ALLOW_CREDENTIALS=true

# Auth / Rate limit
FORGEPILOT_AUTH_MODE=api_key
FORGEPILOT_API_KEYS=admin:replace-me,operator:replace-me
FORGEPILOT_API_KEY_HEADER=x-api-key
FORGEPILOT_AUTH_EXEMPT_PATHS=/,/health

FORGEPILOT_RATE_LIMIT_ENABLED=true
FORGEPILOT_RATE_LIMIT_REQUESTS=120
FORGEPILOT_RATE_LIMIT_WINDOW_SECONDS=60
FORGEPILOT_RATE_LIMIT_BACKEND=redis
FORGEPILOT_RATE_LIMIT_REDIS_URL=redis://redis.internal:6379/0
FORGEPILOT_RATE_LIMIT_REDIS_KEY_PREFIX=forgepilot:ratelimit
FORGEPILOT_RATE_LIMIT_FAIL_OPEN=false

# Runtime state: multi-instance ready
FORGEPILOT_RUNTIME_STATE_BACKEND=redis
FORGEPILOT_RUNTIME_STATE_REDIS_URL=redis://redis.internal:6379/1
FORGEPILOT_RUNTIME_STATE_REDIS_KEY_PREFIX=forgepilot:runtime
FORGEPILOT_RUNTIME_STATE_FAIL_OPEN=false
FORGEPILOT_RUNTIME_PLAN_TTL_SECONDS=3600
FORGEPILOT_RUNTIME_PERMISSION_TTL_SECONDS=1800
FORGEPILOT_PERMISSION_DECISION_TIMEOUT_SECONDS=1800
FORGEPILOT_PERMISSION_POLL_INTERVAL_SECONDS=0.5

# Files module hardening
FORGEPILOT_FILES_MODE=prod
FORGEPILOT_FILES_DANGEROUS_ENABLED=false
FORGEPILOT_FILES_ACL_DEFAULT=files.read
FORGEPILOT_FILES_ACL_SUBJECTS=admin=*;operator=files.read,files.open;viewer=files.read
