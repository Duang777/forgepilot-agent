# ForgePilot Agent - Local Development Defaults
# Copy to `.env` and adjust for your machine.

FORGEPILOT_LOG_LEVEL=INFO
FORGEPILOT_REQUEST_ID_HEADER=x-request-id
FORGEPILOT_EXPOSE_METRICS=true

# CORS
# Dev defaults to "*" if this is unset.
# FORGEPILOT_CORS_ORIGINS=*
FORGEPILOT_CORS_ALLOW_CREDENTIALS=true

# Auth / Rate limit
FORGEPILOT_AUTH_MODE=off
# FORGEPILOT_API_KEYS=local:change-me
FORGEPILOT_API_KEY_HEADER=x-api-key
FORGEPILOT_AUTH_EXEMPT_PATHS=/,/health,/metrics,/docs,/redoc,/openapi.json

FORGEPILOT_RATE_LIMIT_ENABLED=false
FORGEPILOT_RATE_LIMIT_REQUESTS=60
FORGEPILOT_RATE_LIMIT_WINDOW_SECONDS=60
FORGEPILOT_RATE_LIMIT_BACKEND=memory
FORGEPILOT_RATE_LIMIT_REDIS_URL=redis://127.0.0.1:6379/0
FORGEPILOT_RATE_LIMIT_REDIS_KEY_PREFIX=forgepilot:ratelimit
FORGEPILOT_RATE_LIMIT_FAIL_OPEN=true

# Runtime state (session/plan/permission)
FORGEPILOT_RUNTIME_STATE_BACKEND=sqlite
FORGEPILOT_RUNTIME_STATE_REDIS_URL=redis://127.0.0.1:6379/1
FORGEPILOT_RUNTIME_STATE_REDIS_KEY_PREFIX=forgepilot:runtime
FORGEPILOT_RUNTIME_STATE_FAIL_OPEN=true
FORGEPILOT_RUNTIME_PLAN_TTL_SECONDS=3600
FORGEPILOT_RUNTIME_PERMISSION_TTL_SECONDS=1800
FORGEPILOT_PERMISSION_DECISION_TIMEOUT_SECONDS=1800
FORGEPILOT_PERMISSION_POLL_INTERVAL_SECONDS=0.5

# Files security
FORGEPILOT_FILES_MODE=dev
FORGEPILOT_FILES_DANGEROUS_ENABLED=true
FORGEPILOT_FILES_ACL_DEFAULT=*
# FORGEPILOT_FILES_ACL_SUBJECTS=admin=*;operator=files.read,files.open,files.import;viewer=files.read
